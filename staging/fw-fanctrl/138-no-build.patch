From 760c15e289a1f0db7f49066d2a3916660cfdeb20 Mon Sep 17 00:00:00 2001
From: Tulip Blossom <tulilirockz@proton.me>
Date: Fri, 1 May 2026 14:25:03 +0000
Subject: [PATCH] feat(install): add --no-pip-build for RPM-style buildroots

Adds --no-pip-build, which skips both the script's internal
'python3 -m build' step and the subsequent pip install (it implies
--no-pip-install). Useful when the wheel/sdist is built and installed
by the host packaging system (e.g. %pyproject_wheel + %pyproject_install
in an RPM spec). The python3 and 'build' module checks are also gated
on this flag so the script does not require python3 to be present at
all when only generating systemd units and config files.

The earlier --no-override-python-installation-path flag is no longer
needed: the new --effective-installation-dir (added upstream) already
lets the caller pin PYTHON_SCRIPT_INSTALLATION_PATH to /usr/bin/fw-fanctrl
without leaking %{buildroot} into the systemd units.
---
 install.sh | 15 +++++++++++----
 1 file changed, 11 insertions(+), 4 deletions(-)

diff --git a/install.sh b/install.sh
index 44c5367..b1db7eb 100755
--- a/install.sh
+++ b/install.sh
@@ -3,7 +3,7 @@ set -e
 
 # Argument parsing
 SHORT=r,d:,p:,s:,h
-LONG=remove,dest-dir:,prefix-dir:,sysconf-dir:,no-ectool,no-pre-uninstall,no-post-install,no-battery-sensors,no-sudo,no-pip-install,pipx,python-prefix-dir:,effective-installation-dir:,help
+LONG=remove,dest-dir:,prefix-dir:,sysconf-dir:,no-ectool,no-pre-uninstall,no-post-install,no-battery-sensors,no-sudo,no-pip-install,no-pip-build,pipx,python-prefix-dir:,effective-installation-dir:,help
 VALID_ARGS=$(getopt -a --options $SHORT --longoptions $LONG -- "$@")
 if [[ $? -ne 0 ]]; then
     exit 1;
@@ -22,6 +22,7 @@ SHOULD_REMOVE=false
 NO_BATTERY_SENSOR=false
 NO_SUDO=false
 NO_PIP_INSTALL=false
+NO_PIP_BUILD=false
 PIPX=false
 PYTHON_PREFIX_DIRECTORY_OVERRIDE=
 EFFECTIVE_INSTALLATION_DIRECTORY_OVERRIDE=
@@ -62,6 +63,10 @@ while true; do
     '--no-pip-install')
         NO_PIP_INSTALL=true
         ;;
+    '--no-pip-build')
+        NO_PIP_BUILD=true
+        NO_PIP_INSTALL=true
+        ;;
     '--pipx')
         PIPX=true
         ;;
@@ -96,7 +101,7 @@ fi
 
 PYTHON_SCRIPT_INSTALLATION_PATH="$INSTALLATION_DIRECTORY/fw-fanctrl"
 
-if ! python3 -h 1>/dev/null 2>&1; then
+if [ "$NO_PIP_BUILD" = false ] && ! python3 -h 1>/dev/null 2>&1; then
     echo "Missing package 'python3'!"
     exit 1
 fi
@@ -115,7 +120,7 @@ if [ "$PIPX" = true ]; then
     fi
 fi
 
-if [ "$SHOULD_REMOVE" = false ]; then
+if [ "$SHOULD_REMOVE" = false ] && [ "$NO_PIP_BUILD" = false ]; then
     if ! python3 -m build -h 1>/dev/null 2>&1; then
         echo "Missing python package 'build'!"
         exit 1
@@ -232,7 +237,9 @@ function install() {
     fi
     mkdir -p "$DEST_DIR$SYSCONF_DIR/fw-fanctrl"
 
-    build
+    if [ "$NO_PIP_BUILD" = false ]; then
+        build
+    fi
 
     if [ "$NO_PIP_INSTALL" = false ]; then
         echo "installing python package"
-- 
