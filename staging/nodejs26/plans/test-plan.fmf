# Shared metadata between plans
discover:
  how: fmf
  url: https://gitlab.com/redhat/centos-stream/tests/nodejs
  filter: "component:nodejs26"
environment:
  NODEJS_MAIN_PACKAGE: nodejs26
  NODEJS_DEVEL_PACKAGE: nodejs26-devel
  NODEJS_BIN_PACKAGE: nodejs26-bin
  NPM_BIN_PACKAGE: nodejs26-npm-bin
  NODE_BIN: /usr/bin/node-26
  NPM_BIN: /usr/bin/npm-26
  NODE_INCLUDE_PATH: /usr/include/node
execute:
  how: tmt

/main:
  summary: Public downstream Node.js tests
  discover+:
    filter: "component:nodejs26 & tag:-bins"
  prepare:
    - name: install tested packages
      how: install
      package:
        - ${NODEJS_MAIN_PACKAGE}
        - ${NODEJS_DEVEL_PACKAGE}

# introduced in F44
/bin-packages-integration:
  summary: Testing different install/swap scenarios
  environment+:
    OTHER_VERSION_TO_TEST_SWAPS: 22
  prepare:
  - name: remove nodejs from previous tests
    how: shell
    script: dnf remove -y 'nodejs*'
  - name: remove tsflags
    summary: Those prevent dnf from downloading any docs (minimal container stuff)
    how: shell
    script: sed -i 's/tsflags=nodocs/# tsflags=nodocs/' /etc/dnf/dnf.conf
  - name: install man-db
    how: install
    package:
      - man-db
  - name: build-man-index
    how: shell
    script: mandb -c
  discover+:
      filter: 'tag:bins'
